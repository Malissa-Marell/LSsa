    "from tensorflow.keras.regularizers import l2\n",
    "\n",
    "def build_custom_cnn(input_shape=(128, 128, 3), num_classes=3):\n",
    "    model = models.Sequential([\n",
    "        # Input layer\n",
    "        layers.Input(shape=input_shape),\n",
    "\n",
    "        # --- Block 1 ---\n",
    "        layers.Conv2D(32, (3, 3), activation='relu', padding='same'),\n",
    "        layers.BatchNormalization(),  # Stabilizes training\n",
    "        layers.Conv2D(32, (3, 3), activation='relu', padding='same'),\n",
    "        layers.BatchNormalization(),\n",
    "        layers.MaxPooling2D((2, 2)),\n",
    "        layers.SpatialDropout2D(0.25),  # Drops entire feature maps to reduce overfitting\n",
    "\n",
    "        # --- Block 2 ---\n",
    "        layers.Conv2D(64, (3, 3), activation='relu', padding='same'),\n",
    "        layers.BatchNormalization(),\n",
    "        layers.Conv2D(64, (3, 3), activation='relu', padding='same'),\n",
    "        layers.BatchNormalization(),\n",
    "        layers.MaxPooling2D((2, 2)),\n",
    "        layers.SpatialDropout2D(0.25),\n",
    "\n",
    "        # --- Block 3 ---\n",
    "        layers.Conv2D(128, (3, 3), activation='relu', padding='same'),\n",
    "        layers.BatchNormalization(),\n",
    "        layers.Conv2D(128, (3, 3), activation='relu', padding='same'),\n",
    "        layers.BatchNormalization(),\n",
    "        layers.MaxPooling2D((2, 2)),\n",
    "        layers.SpatialDropout2D(0.3),\n",
    "\n",
    "        # --- Classifier Head ---\n",
    "        layers.GlobalAveragePooling2D(),  # Replaces Flatten — fewer parameters\n",
    "        layers.Dense(256, activation='relu', kernel_regularizer=l2(0.001)),  # L2 regularization\n",
    "        layers.Dropout(0.5),\n",
    "        layers.Dense(128, activation='relu', kernel_regularizer=l2(0.001)),\n",
    "        layers.Dropout(0.3),\n",
    "        layers.Dense(num_classes, activation='softmax')  # Output: probability per class\n",
    "    ])\n",
    "    return model\n",
    "\n",
    "cnn_model = build_custom_cnn()\n",
    "cnn_model.summary()"
